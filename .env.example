# Environment variables for the Targeted ABSA inference server.
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# The server starts without requiring these to be set — defaults match the
# standard project layout.  Override only when your checkpoint or data lives
# somewhere else.

# Path to trained checkpoint; copy best_model.pt here or set to its actual location
CHECKPOINT_PATH=checkpoints/best_model.pt

# Directory containing train.jsonl, dev.jsonl, test.jsonl (for Vocabulary build)
DATA_DIR=Data

# Compute device: "cpu" or "cuda"; auto-detected from torch.cuda if unset
DEVICE=cpu

# Encoder architecture key (must match the checkpoint's trained encoder)
# Valid: phobert_large, phobert_base, xlm_roberta_base, xlm_roberta_large
MODEL_ENCODER_KEY=phobert_large

# Attention mechanism key (must match checkpoint training config)
MODEL_ATTENTION_KEY=target_conditioned_attention

# Label output structure (must match checkpoint training config)
MODEL_LABEL_STRUCTURE=multitask_aspect_sentiment

# Comma-separated allowed CORS origins for the frontend dev server
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
